{
  "name": "joblens",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/frontend",
    "apps/api",
    "packages/shared"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "format": "prettier --check . && cargo fmt --manifest-path apps/worker/Cargo.toml --check",
    "format:write": "prettier --write . && cargo fmt --manifest-path apps/worker/Cargo.toml",
    "lint": "npm run lint --workspaces --if-present && cargo clippy --manifest-path apps/worker/Cargo.toml --all-targets -- -D warnings",
    "test": "npm run test --workspaces --if-present && cargo test --manifest-path apps/worker/Cargo.toml",
    "test:db": "npm run test:db --workspace @joblens/api",
    "test:e2e": "playwright test",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "worker:dev": "cargo run --manifest-path apps/worker/Cargo.toml"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.61.1",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "prettier": "^3.0.0",
    "typescript-eslint": "^8.0.0"
  }
}
