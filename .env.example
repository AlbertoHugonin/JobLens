POSTGRES_USER=joblens
POSTGRES_PASSWORD=joblens
POSTGRES_DB=joblens
POSTGRES_PORT=5432

# Docker Compose services should use the postgres service hostname.
# For host-local commands, override with:
# DATABASE_URL=postgresql://joblens:joblens@localhost:5432/joblens
DATABASE_URL=postgresql://joblens:joblens@postgres:5432/joblens

API_HOST=0.0.0.0
API_PORT=3000
API_CORS_ORIGIN=http://localhost:5173
API_RUN_MIGRATIONS=true

FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:3000

WORKER_HOST=0.0.0.0
WORKER_PORT=8090
RUST_LOG=info
WORKER_RUN_LOOP=true
WORKER_POLL_MS=1000
WORKER_HEARTBEAT_MS=1000
WORKER_LEASE_SECONDS=30
WORKER_DUMMY_ACTIVITY_MS=250
# Gentle delay between LinkedIn collection pages (ms). 0 disables pacing.
WORKER_LINKEDIN_PAGE_DELAY_MS=1200
# Cooldown between live LinkedIn job-description fetches (ms). 0 disables pacing.
WORKER_LINKEDIN_DESCRIPTION_COOLDOWN_MS=5000
# Cooldown between live LinkedIn availability checks (ms). 0 disables pacing.
WORKER_LINKEDIN_AVAILABILITY_COOLDOWN_MS=5000

# Optional external AI endpoint. The core app must also work when this is empty.
AI_ENDPOINT_URL=
